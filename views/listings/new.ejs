<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EWA(Explore with Amit)</title>
</head>
<body>
    <form method="POST" action="/listings">
        <input name="listing[title]" placeholder="Enter title" type="text">
        <br><br>
        <textarea name="listing[description]"></textarea>
        <br><br>
        <input name="listing[image]" placeholder="Enter image url/link" type="text">
        <br><br>
        <input name="listing[price]" placeholder="Enter price" type="number">
        <br><br>
        <input name="listing[country]" placeholder="Enter country" type="text">
        <br><br>
        <input name="listing[location]" placeholder="Enter location" type="text">
        <br><br><br>
        <input name="listing[type]" placeholder="Enter type" type="text">
        <br><br>
        <input name="listing[guests]" placeholder="Enter guests" type="text">
        <br><br>
        <input name="listing[bedrooms]" placeholder="Enter bedrooms" type="text">
        <br><br>
        <input name="listing[rating]" placeholder="Enter rating" type="text">
        <br><br>
        <input name="listing[fee]" placeholder="Enter fee" type="text">
        <br><br>
        <br>

        <button>add</button>
        
    </form>
</body>
</html>