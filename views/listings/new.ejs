<% layout("/layouts/boilerplate") %>
<br>
<div class="row mt-3">
  <div class="col-8 off-set-2">
    <h3>Creat & Add new Listing</h3>
    <form method="POST" action="/listings"novalidate class="needs-validation">
      <div class="mb-3">
        <label for="title" class="form-label">Title</label>
        <input
          name="listing[title]"
          placeholder="Add a Catchy Title"
          type="text"
          class="form-control"
          required
        />
      </div>
      <div class="mb-3">
        <label for="description" class="form-label">Description</label>
        <textarea name="listing[description]" class="form-control" required placeholder="Write Discription"></textarea>
      </div>
      <div class="mb-3">
        <label for="image" class="form-label">Image</label>
        <input
          name="listing[image]"
          placeholder="Enter image url/link"
          type="text"
          class="form-control"
          />
      </div>
      <div class="row">
        <div class="mb-3 col-md-4">
          <label for="price" class="form-label">Price</label>
          <input
            name="listing[price]"
            placeholder="Enter price"
            type="number"
            class="form-control"
            required
          />
        </div>
        <div class="mb-3 col-md-8">
          <label for="country" class="form-label">Country</label>
          <input
            name="listing[country]"
            placeholder="Enter country"
            type="text"
            class="form-control"
            required
          />
        </div>
        <div class="mb-3">
          <label for="location" class="form-label">Location</label>
          <input
            name="listing[location]"
            placeholder="Enter location"
            type="text"
            class="form-control"
            required
          />
        </div>
      </div>
      <div class="mb-3">
        <label for="type" class="form-label">Type</label>
        <input
          name="listing[type]"
          placeholder="Enter type"
          type="text"
          class="form-control"
        />
      </div>
      <div class="row">
        <div class="mb-3 col-md-4">
          <label for="guests" class="form-label">Guests</label>
          <input
            name="listing[guests]"
            placeholder="Num of guests"
            type="number"
            class="form-control"

          />
        </div>
        <div class="mb-3 col-md-8">
          <label for="bedrooms" class="form-label">Bedrooms</label>
          <input
            name="listing[bedrooms]"
            placeholder="Number of bedrooms"
            type="number"
            class="form-control"
            required
          />
        </div>
        <div class="mb-3 col-md-4">
          <label for="rating" class="form-label">Rating</label>
          <input
            name="listing[rating]"
            placeholder="Gave us rating"
            type="number"
            class="form-control"

          />
        </div>
        <div class="mb-3 col-md-8">
          <label for="fee" class="form-label">Fee</label>
          <input
            name="listing[fee]"
            placeholder="12000"
            type="number"
            class="form-control"
            required
          />
        </div>
      </div>
      <button class="btn btn-dark add-btn" >Add</button>
      <br><br>
    </form>
  </div>
</div>
